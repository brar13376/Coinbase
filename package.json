{
  "name": "coinbase-clone",
  "version": "1.0.0",
  "description": "Enterprise-grade cryptocurrency exchange platform with microservices architecture",
  "main": "index.js",
  "scripts": {
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm start",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write .",
    "install-all": "npm install && cd client && npm install && cd ../server && npm install && cd ../api-gateway && npm install && cd ../services && find . -name \"package.json\" -exec dirname {} \\; | xargs -I {} sh -c \"cd \\\"{}\\\" && npm install\"",
    "db:init": "node database/install-all.js",
    "db:postgres": "node database/install.js",
    "db:mongodb": "node database/mongodb-init.js",
    "db:redis": "node database/redis-init.js init",
    "db:health": "node database/redis-init.js health",
    "db:cleanup": "node database/redis-init.js cleanup",
    "docker:build": "docker-compose -f docker-compose.prod.yml build",
    "docker:up": "docker-compose -f docker-compose.prod.yml up -d",
    "docker:down": "docker-compose -f docker-compose.prod.yml down",
    "docker:logs": "docker-compose -f docker-compose.prod.yml logs -f",
    "docker:restart": "docker-compose -f docker-compose.prod.yml restart",
    "docker:clean": "docker-compose -f docker-compose.prod.yml down -v && docker system prune -f",
    "deploy": "./deploy.sh",
    "deploy:build": "./deploy.sh build",
    "deploy:start": "./deploy.sh start",
    "deploy:stop": "./deploy.sh stop",
    "deploy:restart": "./deploy.sh restart",
    "deploy:logs": "./deploy.sh logs",
    "deploy:health": "./deploy.sh health",
    "deploy:clean": "./deploy.sh clean",
    "setup": "npm run install-all && npm run db:init",
    "setup:dev": "npm run install-all && npm run db:init && npm run dev",
    "setup:prod": "npm run install-all && npm run db:init && npm run docker:build && npm run docker:up",
    "monitor": "concurrently \"npm run monitor:prometheus\" \"npm run monitor:grafana\"",
    "monitor:prometheus": "cd monitoring && docker-compose up prometheus -d",
    "monitor:grafana": "cd monitoring && docker-compose up grafana -d",
    "logs": "concurrently \"npm run logs:server\" \"npm run logs:client\"",
    "logs:server": "tail -f server/logs/combined.log",
    "logs:client": "tail -f client/logs/combined.log",
    "backup": "node scripts/backup.js",
    "restore": "node scripts/restore.js",
    "migrate": "node scripts/migrate.js",
    "seed": "node scripts/seed.js",
    "health": "node scripts/health-check.js",
    "security:audit": "npm audit && cd client && npm audit && cd ../server && npm audit",
    "security:fix": "npm audit fix && cd client && npm audit fix && cd ../server && npm audit fix",
    "performance:test": "node scripts/performance-test.js",
    "performance:profile": "node --prof scripts/profile.js",
    "docs:generate": "node scripts/generate-docs.js",
    "docs:serve": "node scripts/serve-docs.js",
    "api:test": "newman run docs/postman/coinbase-clone.postman_collection.json",
    "api:mock": "node scripts/mock-server.js",
    "clean": "rm -rf node_modules client/node_modules server/node_modules api-gateway/node_modules services/*/node_modules",
    "clean:logs": "rm -rf logs/*.log",
    "clean:cache": "rm -rf .cache client/.cache server/.cache",
    "clean:all": "npm run clean && npm run clean:logs && npm run clean:cache",
    "update": "npm update && cd client && npm update && cd ../server && npm update",
    "update:check": "npm outdated && cd client && npm outdated && cd ../server && npm outdated",
    "version:patch": "npm version patch && git push && git push --tags",
    "version:minor": "npm version minor && git push && git push --tags",
    "version:major": "npm version major && git push && git push --tags",
    "release": "npm run test && npm run build && npm run version:patch",
    "precommit": "npm run lint && npm run test",
    "prepush": "npm run lint && npm run test && npm run security:audit"
  },
  "keywords": [
    "cryptocurrency",
    "exchange",
    "trading",
    "bitcoin",
    "ethereum",
    "blockchain",
    "microservices",
    "react",
    "nodejs",
    "postgresql",
    "mongodb",
    "redis",
    "docker",
    "kubernetes",
    "fintech",
    "defi",
    "trading-platform",
    "crypto-exchange",
    "digital-assets",
    "web3"
  ],
  "author": "Coinbase Clone Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/coinbase-clone.git"
  },
  "bugs": {
    "url": "https://github.com/your-username/coinbase-clone/issues"
  },
  "homepage": "https://github.com/your-username/coinbase-clone#readme",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0",
    "eslint": "^8.57.0",
    "prettier": "^3.1.1",
    "newman": "^6.0.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4",
    "cross-env": "^7.0.3",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "nyc": "^15.1.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^16.3.1"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm run precommit"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.{js,jsx}",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/dist/**",
      "!**/build/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 2
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended"
    ],
    "env": {
      "browser": true,
      "node": true,
      "es6": true,
      "jest": true
    },
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "error",
      "prefer-const": "error",
      "no-var": "error"
    }
  }
}